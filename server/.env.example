PORT=8800
NODE_ENV=development

MONGO=mongodb://127.0.0.1:27017/pwa-radiant

# Optional: logical DB snapshots (gzip NDJSON, super-admin UI + /api/backup)
# Default folder: server/data/backups (override with absolute path if needed)
# BACKUP_DIR=/var/backups/pwa-radiant
# BACKUP_KEEP_COUNT=30
# BACKUP_CRON=0 3 * * *
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=1d
JWT_COOKIE_EXPIRES_IN=1

CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:8800
PASSWORD_RESET_URL=http://localhost:5173
APP_ROOT_DOMAIN=cxrsystems.com
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
BRAND_APP_NAME=CxR Systems

STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Square Connect (OAuth)
# Use "sandbox" for local/dev and "production" for live
SQUARE_ENV=sandbox
SQUARE_APPLICATION_ID=sq0idp-your-app-id
SQUARE_APPLICATION_SECRET=sq0csp-your-app-secret
# Must exactly match redirect URL in Square Developer Dashboard
SQUARE_REDIRECT_URL=http://localhost:8800/api/square/connect/callback
SQUARE_OAUTH_SCOPES=MERCHANT_PROFILE_READ PAYMENTS_READ PAYMENTS_WRITE ORDERS_READ ORDERS_WRITE
SQUARE_API_VERSION=2026-01-22

# Optional integrations used elsewhere in the app
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

VAPID_MAILTO=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

GHL_API_VERSION=2021-07-28
GHL_LOCATION_API=
GHL_LOCATION_API_MAP=
GHL_BOOKING_PATH_MAP=
GHL_LOCATION_ID=
GHL_SIGNUP_WORKFLOW_ID=
GHL_SIGNUP_WORKFLOW_FALLBACK_ID=
# Optional comma-separated list; tried in order before fallback ID fields above
GHL_SIGNUP_WORKFLOW_IDS=
VERBOSE_SERVER_LOGS=false

# Resend email (password reset)
RESEND_API_KEY=
RESEND_FROM_EMAIL="CxR Systems <onboarding@resend.dev>"
